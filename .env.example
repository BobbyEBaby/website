# ----------------------------------------------------------------------
# RWE Family Law — environment variables
# Copy to `.env.local` for local dev. Do NOT commit the populated file.
# ----------------------------------------------------------------------

# Public URL of the site — used for Stripe return URLs and email links.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Postgres (Neon/Supabase/Railway/local docker). Prisma reads this.
DATABASE_URL="postgresql://user:password@localhost:5432/rwelaw"

# Stripe — test keys locally, live keys in prod.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (transactional email). https://resend.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="RWE Family Law <bookings@rwelaw.ca>"

# Twilio (SMS to lawyers on new bookings). Optional — leave blank to skip.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Admin password for the lawyer dashboard (MVP). Replace with per-user
# auth before going live.
ADMIN_PASSWORD="change-me"

# Vercel Blob — stores the conflict-check dataset (data/conflicts.json) for
# production reads. The library at src/lib/conflict-check.ts reads from blob
# when VERCEL=1 (auto-set on Vercel) and from the local file otherwise.
# Get this from the Vercel dashboard → Storage → your blob store → "Tokens".
# Required locally only if you run `npm run conflicts:push` to update prod.
BLOB_READ_WRITE_TOKEN=""
